# Copy to .env.local and fill in. Never commit the filled-in file.
# Every NEXT_PUBLIC_* var is exposed to the browser — keep secrets out of them.

# ─── Sanity (content) ───────────────────────────────────────────────
# projectId/dataset/apiVersion are public. Code falls back to sensible
# defaults (see src/sanity/env.ts) but set them explicitly in production.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Server-only. Editor token used by /api/blog-published to stamp `notifiedAt`
# on a post after notifying. Create at sanity.io/manage → API → Tokens.
SANITY_WRITE_TOKEN=

# Server-only. Shared secret verifying the Sanity webhook → /api/blog-published.
# Any long random string; paste the SAME value into the Sanity webhook config.
SANITY_WEBHOOK_SECRET=

# ─── Resend (newsletter / blog notifications) ───────────────────────
# Server-only. API key from resend.com/api-keys.
RESEND_API_KEY=
# Id of the "Blog Notifications" segment in Resend (resend.com/segments).
# Resend replaced Audiences with Segments; the old audienceId is deprecated.
RESEND_SEGMENT_ID=
# Sender for broadcast emails — must be on a verified Resend domain.
# Falls back to onboarding@resend.dev (TEST ONLY) if left blank.
RESEND_FROM="Sewitt Fitness <blog@sewittfitness.ca>"
# Optional reply-to: a real, monitored inbox (e.g. a Gmail address). Replies to
# a real human address help notifications land in Gmail's Primary tab instead
# of Promotions. Leave blank to omit the header. Don't use an @sewittfitness.ca
# address unless inbound receiving is enabled for the domain in Resend.
RESEND_REPLY_TO=

# ─── PostHog analytics ──────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
# Note: the app proxies analytics through /ingest, so a POSTHOG_HOST var
# is not read by the code — no need to set one.

# ─── Site ───────────────────────────────────────────────────────────
# Production base URL — used to build absolute post links in notification
# emails. No trailing slash.
NEXT_PUBLIC_SITE_URL=https://www.sewittfitness.ca
